	<script>
    function change_oneclick(name,val){
        document.getElementById("oneclick").innerHTML =name;
        document.getElementById("oneclick").value=val;
        localStorage.setItem("oneclickName", name);
        localStorage.setItem("oneclickVAL", val);
    }
    Cmap = {0: ["#0080FF", 'white', '#005AB5', 'white','gray'],
                1: ["black", "#ffd700", "black", "#ffd700", 'black'],
                2: ["#4d4d4d",  "white","#1AAD19", "#AAAAAA", "#1AAD19"]}
    var themeIdx=localStorage.getItem("themeIdx");
    var oneclickName=localStorage.getItem("oneclickName");
    var oneclickValue=localStorage.getItem("oneclickVAL");
    console.log(oneclickName);
    console.log(oneclickValue);
    if (oneclickName==null||oneclickValue==null){oneclickName="_Al_Azif Mira"; oneclickValue="al";}
    document.getElementById("oneclick").innerHTML=oneclickName;
    document.getElementById("oneclick").value=oneclickValue;
	if (themeIdx==null){themeIdx=0;}
    document.body.style.setProperty('--mainColor', Cmap[themeIdx][0]);
    document.body.style.setProperty('--fontColor',  Cmap[themeIdx][1]);
    document.body.style.setProperty('--attendColor',  Cmap[themeIdx][2]);
    document.body.style.setProperty('--subColor',  Cmap[themeIdx][3]);
    document.body.style.setProperty('--spesColor',  Cmap[themeIdx][4]);
    
    function colorSwitch(){
        themeIdx=themeIdx+1;
        if (themeIdx>2){themeIdx=0}
        //themeIdx=1;
        document.body.style.setProperty('--mainColor', Cmap[themeIdx][0]);
        document.body.style.setProperty('--fontColor',  Cmap[themeIdx][1]);
        document.body.style.setProperty('--attendColor',  Cmap[themeIdx][2]);
        document.body.style.setProperty('--subColor',  Cmap[themeIdx][3]);
    document.body.style.setProperty('--spesColor',  Cmap[themeIdx][4]);
        localStorage.setItem("themeIdx", themeIdx);
    }
    jbnum=localStorage.getItem("jbnum");
	if (jbnum==null){jbnum=0;}
	document.getElementById('jb_ver').options[jbnum].selected=true;
    </script>

